{
  "name": "@compass/utils",
  "version": "1.0.0",
  "description": "{{description}}",
  "main": "lib/main.js",
  "module": "lib/main.js",
  "commonjs": "lib/cjs/main.cjs.js",
  "repository": "https://github.com/Aiden-FE/compass-template/tree/template/utils",
  "author": "Aiden_FE@outlook.com",
  "license": "MIT",
  "files": [
    "lib",
    "types"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "start": "npm run dev",
    "publish:lib": "npm run build && yarn publish --no-git-tag-version",
    "dev": "cross-env NODE_ENV=development rollup -w -c build/rollup.config.dev.js",
    "build": "npm run clean && cross-env NODE_ENV=production rollup -c build/rollup.config.prod.js",
    "test": "jest --coverage",
    "lint": "eslint --ext .ts,.js --ignore-path .gitignore src",
    "clean": "rimraf lib"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^19.0.2",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "@types/jest": "^27.4.1",
    "@types/node": "^17.0.24",
    "@zerollup/ts-transform-paths": "^1.7.18",
    "jest": "^27.5.1",
    "rimraf": "^3.0.2",
    "rollup": "^2.70.1",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-serve": "^1.1.0",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.30.0",
    "ts-jest": "^27.1.3",
    "ts-node": "^10.7.0",
    "tslib": "^2.3.1",
    "ttypescript": "^1.5.13",
    "typescript": "^4.6.2"
  },
  "dependencies": {
    "cross-env": "^7.0.3"
  }
}
