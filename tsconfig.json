{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "ESNext"
    ],
    "strict": true,
    "sourceMap": true,
    "declaration": true, /* 启用声明 */
    "declarationDir": "types", /* 声明文件位置 */
    "allowSyntheticDefaultImports": true, /* 允许从没有设置默认导出的模块中默认导入 */
    "moduleResolution": "node",
    "esModuleInterop": true, /* 允许 import React from 'react' 写法 */
    "resolveJsonModule": true,
    "outDir": "lib",
    "types": [],
    "typeRoots": [
      "src/types",
      "@types/node"
    ]
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
